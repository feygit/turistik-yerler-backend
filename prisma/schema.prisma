generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_PRISMA_URL")
}

model Kullanici {
  id              Int     @id @unique @default(autoincrement())
  eposta          String  @db.VarChar(319) @unique
  sifre           String  @db.VarChar(512)
  ad              String  @db.VarChar(255)
  soyad           String  @db.VarChar(255)
  resim           String  @db.Text @default("")
  epostaOnayliMi  Boolean @default(false)
}